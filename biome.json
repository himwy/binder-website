{
  "$schema": "https://biomejs.dev/schemas/1.9.0/schema.json",
  "organizeImports": { "enabled": true },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": { "all": true },
      "style": { "noNonNullAssertion": "error" },
      "security": { "noDangerouslySetInnerHtml": "off" }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "files": {
    "ignore": [
      "out",
      ".next",
      "node_modules",
      "public/spline",
      "public/screens",
      "scripts",
      "test-results",
      "playwright-report"
    ]
  }
}
